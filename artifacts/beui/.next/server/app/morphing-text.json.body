{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"morphing-text","type":"registry:component","title":"Morphing Text","description":"Auto-cycles through a list of words with each character blurring in from below and out upward with a staggered delay — a melting-and-reforming effect for hero headings.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/motion/morphing-text.tsx","type":"registry:component","target":"@components/motion/morphing-text.tsx"},{"path":"lib/ease.ts","type":"registry:lib","target":"@lib/ease.ts"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}