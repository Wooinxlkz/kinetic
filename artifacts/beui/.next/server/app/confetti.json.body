{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"confetti","type":"registry:component","title":"Confetti","description":"Canvas particle burst (circles, squares, ribbons) fired from any screen position. Exposes a fireConfetti() function and a ConfettiButton convenience wrapper. Respects prefers-reduced-motion.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/motion/confetti.tsx","type":"registry:component","target":"@components/motion/confetti.tsx"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}