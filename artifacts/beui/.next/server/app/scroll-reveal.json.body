{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"scroll-reveal","type":"registry:component","title":"Scroll Animation Scroll Reveal","description":"Reveals its children with a spring slide and blur as they enter the viewport, once or every time. Reduced-motion keeps a fade.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/motion/scroll-reveal.tsx","type":"registry:component","target":"@components/motion/scroll-reveal.tsx"},{"path":"lib/ease.ts","type":"registry:lib","target":"@lib/ease.ts"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}