{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"orbiting-circles","type":"registry:component","title":"Orbiting Circles","description":"Elements orbit a center point at configurable radii, speeds, and phase offsets. Multiple items stay upright throughout via counter-rotation.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/motion/orbiting-circles.tsx","type":"registry:component","target":"@components/motion/orbiting-circles.tsx"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}