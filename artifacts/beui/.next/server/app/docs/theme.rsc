1f:Tbc8d,<pre class="shiki shiki-themes github-light github-dark" style="--shiki-light:#24292e;--shiki-dark:#e1e4e8;--shiki-light-bg:#fff;--shiki-dark-bg:#24292e" tabindex="0"><code><span class="line"><span style="--shiki-light:#D73A49;--shiki-dark:#F97583">@custom-variant</span><span style="--shiki-light:#24292E;--shiki-dark:#E1E4E8"> dark (&#x26;:where(.dark, .dark *));</span></span>
