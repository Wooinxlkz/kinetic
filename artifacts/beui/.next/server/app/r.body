{"name":"beUI","description":"The motion toolkit for React and Next.js.","site":"https://beui.dev","endpoints":{"llms":"https://beui.dev/llms.txt","index":"https://beui.dev/r","shadcn_registry":"https://beui.dev/r/registry.json","shadcn_item":"https://beui.dev/r/{slug}.json","directory_registry":"https://beui.dev/registry.json","directory_item":"https://beui.dev/{slug}.json","detail":"https://beui.dev/r/{slug}","raw":"https://beui.dev/r/{slug}/raw"},"categories":[{"slug":"motion","name":"Components","description":"Bespoke motion primitives with shadcn-compatible registry endpoints."},{"slug":"blocks","name":"Patterns","description":"Composed, product-ready widgets built from beUI motion primitives."},{"slug":"ai","name":"AI","description":"Production-ready UI primitives for chat interfaces, streaming responses, and AI agent workflows."}],"components":[{"slug":"tilt-card","name":"Tilt Card","description":"3D perspective tilt on hover with cursor-tracked glare.","category":"motion","detail_url":"https://beui.dev/r/tilt-card","raw_url":"https://beui.dev/r/tilt-card/raw","page_url":"https://beui.dev/components/motion/tilt-card"},{"slug":"button","name":"Button","description":"Spring-pressed Button plus StatefulButton (idle → loading → success / error) and MagneticButton.","category":"motion","detail_url":"https://beui.dev/r/button","raw_url":"https://beui.dev/r/button/raw","page_url":"https://beui.dev/components/motion/button"},{"slug":"marquee","name":"Marquee","description":"Infinite horizontal or vertical scroll with pause-on-hover.","category":"motion","detail_url":"https://beui.dev/r/marquee","raw_url":"https://beui.dev/r/marquee/raw","page_url":"https://beui.dev/components/motion/marquee"},{"slug":"tabs","name":"Tabs","description":"Pill, segment or underline tabs with a spring layoutId indicator.","category":"motion","detail_url":"https://beui.dev/r/tabs","raw_url":"https://beui.dev/r/tabs/raw","page_url":"https://beui.dev/components/motion/tabs"},{"slug":"switch","name":"Switch","description":"Toggle with a spring-driven thumb and press feedback.","category":"motion","detail_url":"https://beui.dev/r/switch","raw_url":"https://beui.dev/r/switch/raw","page_url":"https://beui.dev/components/motion/switch"},{"slug":"input","name":"Input","description":"Text input with label, left/right icons, error shake and success check draw.","category":"motion","detail_url":"https://beui.dev/r/input","raw_url":"https://beui.dev/r/input/raw","page_url":"https://beui.dev/components/motion/input"},{"slug":"select","name":"Select","description":"Composable select primitives whose panel bouncily unfolds out of the trigger and separates, plus a Morph variant where the trigger grows into the panel via shared layout.","category":"motion","detail_url":"https://beui.dev/r/select","raw_url":"https://beui.dev/r/select/raw","page_url":"https://beui.dev/components/motion/select"},{"slug":"checkbox","name":"Checkbox","description":"Form choice control with a draw-on checkmark, spring press feedback and indeterminate state support.","category":"motion","detail_url":"https://beui.dev/r/checkbox","raw_url":"https://beui.dev/r/checkbox/raw","page_url":"https://beui.dev/components/motion/checkbox"},{"slug":"radio","name":"Radio Group","description":"Single-select choice control with a gliding layoutId indicator dot and spring press feedback.","category":"motion","detail_url":"https://beui.dev/r/radio","raw_url":"https://beui.dev/r/radio/raw","page_url":"https://beui.dev/components/motion/radio"},{"slug":"bottom-sheet","name":"Bottom Sheet","description":"Vaul-inspired draggable bottom sheet with snap points, inertia and glass surface.","category":"motion","detail_url":"https://beui.dev/r/bottom-sheet","raw_url":"https://beui.dev/r/bottom-sheet/raw","page_url":"https://beui.dev/components/motion/bottom-sheet"},{"slug":"shared-layout-bg","name":"Shared Layout Background","description":"A pill that glides between hovered items via motion's shared layout, with blur enter/exit.","category":"motion","detail_url":"https://beui.dev/r/shared-layout-bg","raw_url":"https://beui.dev/r/shared-layout-bg/raw","page_url":"https://beui.dev/components/motion/shared-layout-bg"},{"slug":"dock","name":"Dock","description":"macOS-style dock with grouped actions and a gliding active pill.","category":"motion","detail_url":"https://beui.dev/r/dock","raw_url":"https://beui.dev/r/dock/raw","page_url":"https://beui.dev/components/motion/dock"},{"slug":"tooltip","name":"Tooltip","description":"Hover or focus tooltip with blur enter/exit and spring spawn.","category":"motion","detail_url":"https://beui.dev/r/tooltip","raw_url":"https://beui.dev/r/tooltip/raw","page_url":"https://beui.dev/components/motion/tooltip"},{"slug":"morphing-modal","name":"Morphing Modal","description":"Family-app-style modal. A single panel that morphs its height as you navigate between inner views, with blur cross-fade on content.","category":"motion","detail_url":"https://beui.dev/r/morphing-modal","raw_url":"https://beui.dev/r/morphing-modal/raw","page_url":"https://beui.dev/components/motion/morphing-modal"},{"slug":"text-animation","name":"Text Animation","description":"Animated text primitives for reveal sequences, shimmer loading states and letter-cascade swaps.","category":"motion","detail_url":"https://beui.dev/r/text-animation","raw_url":"https://beui.dev/r/text-animation/raw","page_url":"https://beui.dev/components/motion/text-animation"},{"slug":"number","name":"Number Animation","description":"Animated number primitives for count-up values and rolling digit tickers.","category":"motion","detail_url":"https://beui.dev/r/number","raw_url":"https://beui.dev/r/number/raw","page_url":"https://beui.dev/components/motion/number"},{"slug":"animated-badge","name":"Animated Badge","description":"Status badge with animated state icons, pulse feedback and compact size variants.","category":"motion","detail_url":"https://beui.dev/r/animated-badge","raw_url":"https://beui.dev/r/animated-badge/raw","page_url":"https://beui.dev/components/motion/animated-badge"},{"slug":"action-swap","name":"Action Swap","description":"CTA button and slot primitives for swapping text and icons with blur motion.","category":"motion","detail_url":"https://beui.dev/r/action-swap","raw_url":"https://beui.dev/r/action-swap/raw","page_url":"https://beui.dev/components/motion/action-swap"},{"slug":"animated-toast-stack","name":"Animated Toast Stack","description":"Stacked toasts with status morphs, swipe dismissal, actions and layout-aware motion.","category":"motion","detail_url":"https://beui.dev/r/animated-toast-stack","raw_url":"https://beui.dev/r/animated-toast-stack/raw","page_url":"https://beui.dev/components/motion/animated-toast-stack"},{"slug":"theme-toggle","name":"Theme Toggle","description":"Theme toggle button with a full-page rectangle clip-path reveal via the View Transition API.","category":"motion","detail_url":"https://beui.dev/r/theme-toggle","raw_url":"https://beui.dev/r/theme-toggle/raw","page_url":"https://beui.dev/components/motion/theme-toggle"},{"slug":"bouncy-accordion","name":"Bouncy Accordion","description":"Single-open accordion with weighted spring layout, icon rows and reduced-motion-safe content reveals.","category":"motion","detail_url":"https://beui.dev/r/bouncy-accordion","raw_url":"https://beui.dev/r/bouncy-accordion/raw","page_url":"https://beui.dev/components/motion/bouncy-accordion"},{"slug":"drawer","name":"Drawer","description":"Side panel that slides in from the left or right with a spring, backdrop blur, body scroll lock and esc-to-close.","category":"motion","detail_url":"https://beui.dev/r/drawer","raw_url":"https://beui.dev/r/drawer/raw","page_url":"https://beui.dev/components/motion/drawer"},{"slug":"scroll-animation","name":"Scroll Animation","description":"Scroll-driven motion: a Lenis smooth-scroll provider and a reading-progress indicator that reads from it.","category":"motion","detail_url":"https://beui.dev/r/scroll-animation","raw_url":"https://beui.dev/r/scroll-animation/raw","page_url":"https://beui.dev/components/motion/scroll-animation"},{"slug":"range-slider","name":"Range Slider","description":"Range slider with tick dots and a bouncy vertical-bar thumb that glides between snapped steps; drag and keyboard control, reduced-motion safe.","category":"motion","detail_url":"https://beui.dev/r/range-slider","raw_url":"https://beui.dev/r/range-slider/raw","page_url":"https://beui.dev/components/motion/range-slider"},{"slug":"table","name":"Table","description":"Virtualized data table that stays smooth at 10k+ rows, with sortable headers, row selection, column resize and reorder, and a sticky header. Minimal, reduced-motion-safe motion.","category":"motion","detail_url":"https://beui.dev/r/table","raw_url":"https://beui.dev/r/table/raw","page_url":"https://beui.dev/components/motion/table"},{"slug":"shader-background","name":"Shader Background","description":"Canvas shader backgrounds (mesh gradient, grain, warp, waves, voronoi, dot orbit and more) with a single typed variant prop. Reduced-motion freezes animated variants.","category":"motion","detail_url":"https://beui.dev/r/shader-background","raw_url":"https://beui.dev/r/shader-background/raw","page_url":"https://beui.dev/components/motion/shader-background"},{"slug":"cylinder-carousel","name":"Cylinder Carousel","description":"A carousel whose items line the inside of a cylinder, receding into the center and growing toward the edges. Drag, scroll or arrow-key to roll it, with a springy glide and snap. Reduced-motion drops the glide.","category":"motion","detail_url":"https://beui.dev/r/cylinder-carousel","raw_url":"https://beui.dev/r/cylinder-carousel/raw","page_url":"https://beui.dev/components/motion/cylinder-carousel"},{"slug":"loader","name":"Loader","description":"Loading indicator with seventeen variants: spinner, dots, bars, dot-matrix, dither, morph, comet, scramble, metaballs, newton, helix, percent, and five terminal-style ascii spinners. Scales from one size prop, uses currentColor, and reduced-motion swaps every transform for a calm opacity pulse.","category":"motion","detail_url":"https://beui.dev/r/loader","raw_url":"https://beui.dev/r/loader/raw","page_url":"https://beui.dev/components/motion/loader"},{"slug":"dialog","name":"Dialog","description":"Spring-scale modal with backdrop blur, focus trap, Esc-to-close, and body scroll lock. Composable sub-components: Dialog, DialogTrigger, DialogContent, DialogHeader, DialogTitle, DialogDescription, DialogFooter, DialogClose.","category":"motion","detail_url":"https://beui.dev/r/dialog","raw_url":"https://beui.dev/r/dialog/raw","page_url":"https://beui.dev/components/motion/dialog"},{"slug":"dropdown-menu","name":"Dropdown Menu","description":"Click-triggered positioned menu with staggered item entrance, separator, label, shortcut and destructive variants. Closes on outside click, item select, or Esc.","category":"motion","detail_url":"https://beui.dev/r/dropdown-menu","raw_url":"https://beui.dev/r/dropdown-menu/raw","page_url":"https://beui.dev/components/motion/dropdown-menu"},{"slug":"popover","name":"Popover","description":"Click-triggered floating panel with side and alignment control, spring blur entrance, and outside-click / Esc dismissal. Composable sub-components: Popover, PopoverTrigger, PopoverContent, PopoverClose.","category":"motion","detail_url":"https://beui.dev/r/popover","raw_url":"https://beui.dev/r/popover/raw","page_url":"https://beui.dev/components/motion/popover"},{"slug":"progress","name":"Progress","description":"Animated progress bar with spring fill, five status variants (default, success, warning, error, info), four sizes, indeterminate mode, and a StackedProgress multi-segment variant with legend.","category":"motion","detail_url":"https://beui.dev/r/progress","raw_url":"https://beui.dev/r/progress/raw","page_url":"https://beui.dev/components/motion/progress"},{"slug":"textarea","name":"Textarea","description":"Auto-resizing textarea with spring error-shake, success/error state icons, floating label, hint text, and min/max row bounds. Same classNames API as the motion Input.","category":"motion","detail_url":"https://beui.dev/r/textarea","raw_url":"https://beui.dev/r/textarea/raw","page_url":"https://beui.dev/components/motion/textarea"},{"slug":"skeleton","name":"Skeleton","description":"Shimmer loading placeholder with rect, circle, and multi-line text variants, plus SkeletonCard and SkeletonTable composites. Reduced-motion falls back to opacity pulse.","category":"motion","detail_url":"https://beui.dev/r/skeleton","raw_url":"https://beui.dev/r/skeleton/raw","page_url":"https://beui.dev/components/motion/skeleton"},{"slug":"avatar","name":"Avatar","description":"Image with animated fallback (initials or icon), six sizes, four status dot indicators, and an AvatarGroup stacked with spring entrance and overflow counter.","category":"motion","detail_url":"https://beui.dev/r/avatar","raw_url":"https://beui.dev/r/avatar/raw","page_url":"https://beui.dev/components/motion/avatar"},{"slug":"combobox","name":"Combobox","description":"Searchable select with spring dropdown, layout-animated filtered list, selected checkmark, description rows, icon support, clear button, and an empty state.","category":"motion","detail_url":"https://beui.dev/r/combobox","raw_url":"https://beui.dev/r/combobox/raw","page_url":"https://beui.dev/components/motion/combobox"},{"slug":"text-morph","name":"Text Morph","description":"Morphs between strings character-by-character via layoutId — shared characters physically glide to their new positions, removed ones fade out, new ones fade in.","category":"motion","detail_url":"https://beui.dev/r/text-morph","raw_url":"https://beui.dev/r/text-morph/raw","page_url":"https://beui.dev/components/motion/text-morph"},{"slug":"morphing-text","name":"Morphing Text","description":"Auto-cycles through a list of words with each character blurring in from below and out upward with a staggered delay — a melting-and-reforming effect for hero headings.","category":"motion","detail_url":"https://beui.dev/r/morphing-text","raw_url":"https://beui.dev/r/morphing-text/raw","page_url":"https://beui.dev/components/motion/morphing-text"},{"slug":"magic-card","name":"Magic Card","description":"Card with a spring-following radial gradient spotlight that tracks the cursor. The surface stays flat while a light source moves behind it.","category":"motion","detail_url":"https://beui.dev/r/magic-card","raw_url":"https://beui.dev/r/magic-card/raw","page_url":"https://beui.dev/components/motion/magic-card"},{"slug":"border-beam","name":"Border Beam","description":"A sweeping gradient comet that travels clockwise around the border of its container. Drop it inside any positioned element to add a dynamic border highlight.","category":"motion","detail_url":"https://beui.dev/r/border-beam","raw_url":"https://beui.dev/r/border-beam/raw","page_url":"https://beui.dev/components/motion/border-beam"},{"slug":"orbiting-circles","name":"Orbiting Circles","description":"Elements orbit a center point at configurable radii, speeds, and phase offsets. Multiple items stay upright throughout via counter-rotation.","category":"motion","detail_url":"https://beui.dev/r/orbiting-circles","raw_url":"https://beui.dev/r/orbiting-circles/raw","page_url":"https://beui.dev/components/motion/orbiting-circles"},{"slug":"confetti","name":"Confetti","description":"Canvas particle burst (circles, squares, ribbons) fired from any screen position. Exposes a fireConfetti() function and a ConfettiButton convenience wrapper. Respects prefers-reduced-motion.","category":"motion","detail_url":"https://beui.dev/r/confetti","raw_url":"https://beui.dev/r/confetti/raw","page_url":"https://beui.dev/components/motion/confetti"},{"slug":"animated-beam","name":"Animated Beam","description":"SVG beam that connects two DOM elements with an animated traveling spot of light along a static dim track. Supports bezier curvature, reverse direction, and multiple beams.","category":"motion","detail_url":"https://beui.dev/r/animated-beam","raw_url":"https://beui.dev/r/animated-beam/raw","page_url":"https://beui.dev/components/motion/animated-beam"},{"slug":"flickering-grid","name":"Flickering Grid","description":"Canvas grid where each cell independently and randomly updates its opacity, creating a living breathing background texture. Lightweight and customizable.","category":"motion","detail_url":"https://beui.dev/r/flickering-grid","raw_url":"https://beui.dev/r/flickering-grid/raw","page_url":"https://beui.dev/components/motion/flickering-grid"},{"slug":"wheel-picker","name":"Wheel Picker","description":"iOS-style 3D cylinder picker with physics-based flick, touch drag, mouse drag, trackpad wheel, and keyboard navigation. Controlled and uncontrolled. Reduced-motion safe.","category":"motion","detail_url":"https://beui.dev/r/wheel-picker","raw_url":"https://beui.dev/r/wheel-picker/raw","page_url":"https://beui.dev/components/motion/wheel-picker"},{"slug":"swap","name":"Multi-chain Swap","description":"Cross-chain swap widget with chain + token selectors, morphing views, animated flip and quote.","category":"blocks","detail_url":"https://beui.dev/r/swap","raw_url":"https://beui.dev/r/swap/raw","page_url":"https://beui.dev/components/blocks/swap"},{"slug":"dynamic-island","name":"Dynamic Island","description":"iOS-style island pill that morphs between live activity views with bouncy shell resize and blur crossfades.","category":"blocks","detail_url":"https://beui.dev/r/dynamic-island","raw_url":"https://beui.dev/r/dynamic-island/raw","page_url":"https://beui.dev/components/blocks/dynamic-island"},{"slug":"command-palette","name":"Command Palette","description":"⌘K palette with fuzzy filter, spring-animated active row and glass surface.","category":"blocks","detail_url":"https://beui.dev/r/command-palette","raw_url":"https://beui.dev/r/command-palette/raw","page_url":"https://beui.dev/components/blocks/command-palette"},{"slug":"expandable-action-bar","name":"Expandable Action Bar","description":"Compact icon actions that expand into labeled controls on hover or focus with shared layout motion.","category":"blocks","detail_url":"https://beui.dev/r/expandable-action-bar","raw_url":"https://beui.dev/r/expandable-action-bar/raw","page_url":"https://beui.dev/components/blocks/expandable-action-bar"},{"slug":"overflow-actions","name":"Overflow Actions","description":"Connected pill rail for primary actions that springs open to reveal extra controls.","category":"blocks","detail_url":"https://beui.dev/r/overflow-actions","raw_url":"https://beui.dev/r/overflow-actions/raw","page_url":"https://beui.dev/components/blocks/overflow-actions"},{"slug":"expandable-tabs","name":"Expandable Tabs","description":"Icon tab bar where the active tab expands to a labelled pill, with a panel above that morphs height and slides content direction-aware on switch.","category":"blocks","detail_url":"https://beui.dev/r/expandable-tabs","raw_url":"https://beui.dev/r/expandable-tabs/raw","page_url":"https://beui.dev/components/blocks/expandable-tabs"},{"slug":"swipeable-list","name":"Swipeable List","description":"Mobile-style list rows that swipe left or right to reveal contextual action buttons.","category":"blocks","detail_url":"https://beui.dev/r/swipeable-list","raw_url":"https://beui.dev/r/swipeable-list/raw","page_url":"https://beui.dev/components/blocks/swipeable-list"},{"slug":"file-upload","name":"File Upload","description":"Drag-and-drop upload queue with progress rows, retry/remove actions and reduced-motion-safe state changes.","category":"blocks","detail_url":"https://beui.dev/r/file-upload","raw_url":"https://beui.dev/r/file-upload/raw","page_url":"https://beui.dev/components/blocks/file-upload"},{"slug":"prediction-market","name":"Prediction Market","description":"Prediction market trade ticket with buy/sell modes, outcome prices, rolling amount entry, quick add chips and trade states.","category":"blocks","detail_url":"https://beui.dev/r/prediction-market","raw_url":"https://beui.dev/r/prediction-market/raw","page_url":"https://beui.dev/components/blocks/prediction-market"},{"slug":"wallet-card","name":"Wallet Card","description":"Wallet overview card with an account switcher and search that morph open from their triggers, a cascading balance with a live change pill and privacy toggle, copy-address, and Send / Deposit / Swap / Buy actions.","category":"blocks","detail_url":"https://beui.dev/r/wallet-card","raw_url":"https://beui.dev/r/wallet-card/raw","page_url":"https://beui.dev/components/blocks/wallet-card"},{"slug":"otp-input","name":"OTP Input","description":"One-time-code input with a gliding focus ring, digits that roll in per slot, error shake and a success check draw.","category":"blocks","detail_url":"https://beui.dev/r/otp-input","raw_url":"https://beui.dev/r/otp-input/raw","page_url":"https://beui.dev/components/blocks/otp-input"},{"slug":"bloom-menu","name":"Bloom Menu","description":"A button that morphs open into a menu and blooms iris-out from the center, the grid revealing in every direction with radially staggered items.","category":"blocks","detail_url":"https://beui.dev/r/bloom-menu","raw_url":"https://beui.dev/r/bloom-menu/raw","page_url":"https://beui.dev/components/blocks/bloom-menu"},{"slug":"feedback-widget","name":"Feedback Widget","description":"Corner trigger that morphs open into a feedback popup with message entry and animated sending, success and retry states.","category":"blocks","detail_url":"https://beui.dev/r/feedback-widget","raw_url":"https://beui.dev/r/feedback-widget/raw","page_url":"https://beui.dev/components/blocks/feedback-widget"},{"slug":"not-found","name":"404 / Not Found","description":"Animated 404 pages in five styles: glitch scramble, magnetic digits, cursor spotlight, a fanning card stack and a typed terminal.","category":"blocks","detail_url":"https://beui.dev/r/not-found","raw_url":"https://beui.dev/r/not-found/raw","page_url":"https://beui.dev/components/blocks/not-found"},{"slug":"hero-video-dialog","name":"Hero Video Dialog","description":"Thumbnail with an animated play button that opens a fullscreen video dialog. Supports YouTube / Vimeo embed URLs or direct video files. Six configurable entry animations.","category":"blocks","detail_url":"https://beui.dev/r/hero-video-dialog","raw_url":"https://beui.dev/r/hero-video-dialog/raw","page_url":"https://beui.dev/components/blocks/hero-video-dialog"},{"slug":"agent-input","name":"Agent Input","description":"Auto-resizing chat input with send / stop states, suggestion chips, and staged file attachments — wires directly into any AI SDK.","category":"ai","detail_url":"https://beui.dev/r/agent-input","raw_url":"https://beui.dev/r/agent-input/raw","page_url":"https://beui.dev/components/ai/agent-input"},{"slug":"chat-bubble","name":"Chat Bubble","description":"Animated user and assistant message bubbles with a spring entry, typing indicator, and a composable MessageList for full conversation threads.","category":"ai","detail_url":"https://beui.dev/r/chat-bubble","raw_url":"https://beui.dev/r/chat-bubble/raw","page_url":"https://beui.dev/components/ai/chat-bubble"},{"slug":"streaming-text","name":"Streaming Text","description":"Character-by-character text reveal that tracks append-only target strings — simulates live token streaming. Includes a blinking cursor and a word-level TokenStream variant.","category":"ai","detail_url":"https://beui.dev/r/streaming-text","raw_url":"https://beui.dev/r/streaming-text/raw","page_url":"https://beui.dev/components/ai/streaming-text"},{"slug":"tool-card","name":"Tool Card","description":"Collapsible card for AI tool invocations — shows the tool name, status (running / done / error) with spring-animated icon transitions, and an expandable input / output body.","category":"ai","detail_url":"https://beui.dev/r/tool-card","raw_url":"https://beui.dev/r/tool-card/raw","page_url":"https://beui.dev/components/ai/tool-card"}]}