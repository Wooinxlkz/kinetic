{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"border-beam","type":"registry:component","title":"Border Beam","description":"A sweeping gradient comet that travels clockwise around the border of its container. Drop it inside any positioned element to add a dynamic border highlight.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/motion/border-beam.tsx","type":"registry:component","target":"@components/motion/border-beam.tsx"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}