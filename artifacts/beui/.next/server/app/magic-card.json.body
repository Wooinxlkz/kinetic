{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"magic-card","type":"registry:component","title":"Magic Card","description":"Card with a spring-following radial gradient spotlight that tracks the cursor. The surface stays flat while a light source moves behind it.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/motion/magic-card.tsx","type":"registry:component","target":"@components/motion/magic-card.tsx"},{"path":"lib/ease.ts","type":"registry:lib","target":"@lib/ease.ts"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}