{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"streaming-text","type":"registry:component","title":"Streaming Text","description":"Character-by-character text reveal that tracks append-only target strings — simulates live token streaming. Includes a blinking cursor and a word-level TokenStream variant.","author":"Saurabh <saurabh10102@gmail.com>","dependencies":["clsx","motion","tailwind-merge"],"registryDependencies":[],"files":[{"path":"components/ai/streaming-text.tsx","type":"registry:component","target":"@components/ai/streaming-text.tsx"},{"path":"lib/utils.ts","type":"registry:lib","target":"@lib/utils.ts"}]}